# YieldMind Environment Configuration
# Replace the values below with your actual keys

# ============================================
# 1. WALLET PRIVATE KEY (REQUIRED)
# ============================================
# Get from MetaMask:
# 1. Click three dots → Account details
# 2. Show private key → Enter password
# 3. Copy the key (66 characters: 0x + 64 hex)
#
# Example: 0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
PRIVATE_KEY=PASTE_YOUR_PRIVATE_KEY_HERE

# ============================================
# 2. RPC ENDPOINTS (Already configured)
# ============================================
BASE_SEPOLIA_RPC=https://sepolia.base.org
STATUS_SEPOLIA_RPC=https://public.sepolia.rpc.status.network

# ============================================
# 3. API KEYS
# ============================================

# Basescan API Key (for contract verification)
# Get from: https://basescan.org/apis
# 1. Register account
# 2. Create API key
# 3. Copy and paste below
BASESCAN_API_KEY=PASTE_YOUR_BASESCAN_KEY_HERE

# Venice AI API Key (OPTIONAL - can leave empty)
# Get from: https://venice.ai
# If empty, agent will use mock responses
VENICE_API_KEY=

# ============================================
# 4. CONTRACT ADDRESSES
# ============================================
# Leave empty - will be filled after deployment
TREASURY_ADDRESS=
AGENT_ADDRESS=
WSTETH_ADDRESS=0x0000000000000000000000000000000000000001
LIDO_ADDRESS=0x0000000000000000000000000000000000000002

# ============================================
# 5. OPTIONAL SETTINGS
# ============================================
VENICE_PAYMENT_ADDRESS=
PORT=3000

# ============================================
# CHECKLIST BEFORE RUNNING:
# ============================================
# [ ] PRIVATE_KEY is 66 characters (0x + 64 hex)
# [ ] Got testnet ETH from https://faucet.coinbase.com
# [ ] BASESCAN_API_KEY added (or left empty for now)
# [ ] Saved this file as .env (not .env.template)
# [ ] Ready to run: npm run compile
